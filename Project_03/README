TaskFlow - Interactive Task Manager

Status: Active
Built with HTML5, CSS3, JavaScript
Project 3 — Interactive Web Elements | Internship Task

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

OVERVIEW

TaskFlow is an interactive task management application built with vanilla HTML, 
CSS, and JavaScript. It demonstrates the IPO Model (Input, Process, Output) 
through DOM manipulation, event handling, and state management.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

LEARNING OBJECTIVES

DOM Selection      : querySelector, getElementById
Event Listeners    : click, submit, input, keydown
State Management   : Variables + localStorage
Dynamic Updates    : textContent, innerHTML (sanitized)
Class Toggling     : classList.toggle()
const vs let       : const for DOM refs, let for state

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

FEATURES

• Add/Delete Tasks — Full CRUD operations
• Complete Tasks — Toggle with checkbox
• Important Flag — Star important tasks
• Priority Levels — Low / Medium / High
• Filter System — All / Active / Completed / Important
• Search — Real-time task filtering
• Dark Mode — Theme toggle with CSS variables
• Statistics — Live task metrics dashboard
• Keyboard Shortcuts — Ctrl+K to search
• Local Storage — Persistent data
• Toast Notifications — User feedback
• Responsive Design — Mobile-friendly sidebar

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

TECH STACK

HTML5              - Semantic structure
CSS3               - Variables, Grid, Flexbox, Dark Mode
JavaScript (ES6+)  - DOM, Events, State
Font Awesome 6     - Icons
Google Fonts       - Inter + Poppins

Zero dependencies. No frameworks.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

PROJECT STRUCTURE

taskflow/
  ├── index.html    (Structure)
  ├── style.css     (Styling + Dark Mode)
  ├── script.js     (All functionality)
  └── README.md     (Documentation)

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

QUICK START

git clone https://github.com/yourusername/taskflow.git
cd taskflow
open index.html

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

IPO MODEL IMPLEMENTATION

User clicks Add       : validateInput()   : Task appears in list
User clicks checkbox  : toggleComplete()  : Text strikethrough
User clicks star      : toggleImportant() : Star fills yellow
User clicks filter    : setFilter()       : List filters
User clicks theme     : toggleDarkMode()  : Theme changes
User types search     : filterTasks()     : Results update

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

STATE VARIABLES

let tasks = [];                // Task array
let currentFilter = 'all';     // Active filter
let currentPriority = 'medium'; // Default priority
let isDarkMode = false;        // Theme state

